<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="module_category_sita_pay" model="ir.module.category">
            <field name="name">SITA-PAY</field>
            <field name="description">Helps you manage your Transactions</field>
            <field name="sequence">3</field>
        </record>
        <record id="group_readonly_user" model="res.groups">
            <field name="name">ReadOnly Access</field>
            <field name="category_id" ref="sita_payment_integration.module_category_sita_pay"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="full_access_user" model="res.groups">
            <field name="name">Full Access</field>
            <field name="category_id" ref="sita_payment_integration.module_category_sita_pay"/>
            <field name="implied_ids" eval="[(4, ref('sita_payment_integration.group_readonly_user'))]"/>
            

        </record>

        <record id="base.default_user" model="res.users">
        <field name="groups_id" eval="[(4,ref('sita_payment_integration.full_access_user'))]"/>
    </record>

        <record id="super_admin_access_user" model="res.groups">
            <field name="name">Super Admin</field>
            <field name="category_id" ref="sita_payment_integration.module_category_sita_pay"/>
            <field name="implied_ids" eval="[(4, ref('sita_payment_integration.full_access_user'))]"/>
        </record>
        <record id="group_pay_his_documents" model="res.groups">
            <field name="name">User Documents Only</field>
            <field name="category_id" ref="module_category_sita_pay"/>
        </record>

        <record id="group_all_documents" model="res.groups">
            <field name="name">All Documents</field>
            <field name="category_id" ref="module_category_sita_pay"/>
            <field name="implied_ids" eval="[(4, ref('sita_payment_integration.group_pay_his_documents'))]"/>

        </record>

        <record id="dashboards_viewer" model="res.groups">
            <field name="name">DashBoard Viewer</field>
            <field name="category_id" ref="module_category_sita_pay"/>
        </record>

        <record id="accounts_viewer" model="res.groups">
            <field name="name">Accounts Viewer</field>
            <field name="category_id" ref="module_category_sita_pay"/>
        </record>


         <record id="create_refund" model="res.groups">
            <field name="name">Make Refund</field>
            <field name="category_id" ref="module_category_sita_pay"/>
        </record>


        <record model="ir.rule" id="record_restricted_company_rule">
            <field name="name">Restricted Record: multi-company</field>
            <field name="model_id" ref="model_transaction"/>
            <field name="global" eval="True"/>
            <field name="domain_force">
                [('company_id', 'in', company_ids)]
            </field>
        </record>

        <!--		Transaction Rules-->
        <record model="ir.rule" id="record_restricted_transaction_rule">
            <field name="name">User Transaction Only</field>
            <field name="model_id" ref="model_transaction"/>
            <field name="groups" eval="[(4,ref('group_pay_his_documents'))]"/>
            <field name="domain_force">
                [('user_id', '=', user.id)]
            </field>
        </record>
        <record model="ir.rule" id="record_all_transaction_rule">
            <field name="name">All Transactions</field>
            <field name="model_id" ref="model_transaction"/>
            <field name="groups" eval="[(4,ref('group_all_documents'))]"/>
            <field name="domain_force">
                []
            </field>
        </record>


    </data>
</odoo>